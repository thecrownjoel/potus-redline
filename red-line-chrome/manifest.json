{
  "manifest_version": 3,
  "name": "Red Line — Direct from the White House",
  "version": "1.0.0",
  "description": "Your verified, bot-proof connection to the Oval Office. Get breaking alerts, participate in verified polls, and receive presidential communications.",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://www.whitehouse.gov/*",
    "https://whitehouse.gov/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.whitehouse.gov/*", "https://whitehouse.gov/*"],
      "js": ["js/content.js"],
      "css": ["css/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
